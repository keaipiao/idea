# IdeaBox 后端环境变量模板
# 复制为 .env 后填实际值。.env 已在 .gitignore 中,不会入仓。

# ========== 数据库(本地 dev) ==========
# docker-compose.dev.yml 用的 PG 容器配置
# 2026-05-28 PR-3 改 5432 → 25432 避与本机其他 PG 实例冲突;容器内仍 5432
POSTGRES_HOST=localhost
POSTGRES_PORT=25432
POSTGRES_DB=ideabox
POSTGRES_USER=ideabox
POSTGRES_PASSWORD=ideabox_dev_password

# Spring Boot 拼数据库 URL 用的(默认从上面 5 项拼)
DATASOURCE_URL=jdbc:postgresql://localhost:25432/ideabox

# ========== Redis(未引入,占位) ==========
# 若未来 PR(eg PR-7 搜索 / 标签)引入 Redis,使用 26380 端口避标准 6379 冲突
# REDIS_HOST=localhost
# REDIS_PORT=26380

# ========== JWT ==========
# HMAC-SHA256 签名密钥,必须 >= 32 字节随机串
# 生成方式(任选):
#   openssl rand -base64 48
#   PowerShell: [Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(48))
IDEABOX_JWT_SECRET=CHANGE_ME_TO_RANDOM_32_PLUS_BYTES_BASE64_STRING_HERE_NEVER_COMMIT

# JWT 有效期(小时),默认 168 = 7 天
IDEABOX_JWT_EXPIRATION_HOURS=168

# ========== Spring Profile ==========
# dev / test / prod。本地开发用 dev
SPRING_PROFILES_ACTIVE=dev
